
FREQUENCIES VARIABLES=Sexe Ville Réligion SituationMatrimoniale NiveauInstruction TrancheAge 
    EtatSante NiveauDeVie
  /PIECHART FREQ
  /ORDER=ANALYSIS.

DESCRIPTIVES VARIABLES=Âge Nombredenfants Salaire Ancienté QuantGras EpaisTriceps CirconfCuisse 
    CirconfAvantBras
  /STATISTICS=MEAN STDDEV VARIANCE RANGE MIN MAX KURTOSIS SKEWNESS.

CROSSTABS
  /TABLES=Sexe BY Ville
  /FORMAT=AVALUE TABLES
  /CELLS=COUNT TOTAL 
  /COUNT ROUND CELL.

CROSSTABS
  /TABLES=Sexe BY SituationMatrimoniale
  /FORMAT=AVALUE TABLES
  /CELLS=COUNT TOTAL 
  /COUNT ROUND CELL.

CROSSTABS
  /TABLES=NiveauInstruction BY SituationMatrimoniale
  /FORMAT=AVALUE TABLES
  /STATISTICS=CHISQ PHI 
  /CELLS=COUNT TOTAL 
  /COUNT ROUND CELL.

CROSSTABS
  /TABLES=EtatSante BY NiveauDeVie
  /FORMAT=AVALUE TABLES
  /STATISTICS=CHISQ UC 
  /CELLS=COUNT TOTAL 
  /COUNT ROUND CELL.

EXAMINE VARIABLES=Nombredenfants Salaire Ancienté
  /PLOT BOXPLOT HISTOGRAM NPPLOT
  /COMPARE GROUPS
  /STATISTICS DESCRIPTIVES
  /CINTERVAL 95
  /MISSING LISTWISE
  /NOTOTAL.

EXAMINE VARIABLES=QuantGras EpaisTriceps CirconfCuisse CirconfAvantBras
  /PLOT BOXPLOT STEMLEAF HISTOGRAM NPPLOT
  /COMPARE GROUPS
  /STATISTICS DESCRIPTIVES
  /CINTERVAL 95
  /MISSING LISTWISE
  /NOTOTAL.

CORRELATIONS
  /VARIABLES=QuantGras EpaisTriceps CirconfCuisse CirconfAvantBras
  /PRINT=TWOTAIL NOSIG
  /STATISTICS DESCRIPTIVES XPROD
  /MISSING=PAIRWISE.

MEANS TABLES=Salaire BY Sexe
  /CELLS=MEAN COUNT STDDEV SUM MIN MAX RANGE.

USE ALL.
COMPUTE filter_$=(Réligion = 1).
VARIABLE LABELS filter_$ 'Réligion = 1 (FILTER)'.
VALUE LABELS filter_$ 0 'Not Selected' 1 'Selected'.
FORMATS filter_$ (f1.0).
FILTER BY filter_$.
EXECUTE.

FREQUENCIES VARIABLES=SituationMatrimoniale
  /PIECHART FREQ
  /ORDER=ANALYSIS.

FILTER OFF.
USE ALL.
EXECUTE.

SORT CASES  BY Ville.
SPLIT FILE LAYERED BY Ville.

DESCRIPTIVES VARIABLES=Âge
  /STATISTICS=MEAN STDDEV VARIANCE RANGE MIN MAX KURTOSIS SKEWNESS.

SPLIT FILE OFF.

T-TEST GROUPS=Sexe(1 2)
  /MISSING=ANALYSIS
  /VARIABLES=Salaire
  /CRITERIA=CI(.95).

NONPAR CORR
  /VARIABLES=EtatSante NiveauDeVie
  /PRINT=SPEARMAN TWOTAIL NOSIG
  /MISSING=PAIRWISE.

ONEWAY Ancienté BY SituationMatrimoniale
  /MISSING ANALYSIS
  /POSTHOC=TUKEY DUNCAN SCHEFFE BONFERRONI SIDAK T2 T3 DUNNETT ALPHA(0.05).

* Générateur de graphiques.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=NiveauInstruction Âge MISSING=LISTWISE 
    REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: NiveauInstruction=col(source(s), name("NiveauInstruction"), unit.category())
  DATA: Âge=col(source(s), name("Âge"))
  DATA: id=col(source(s), name("$CASENUM"), unit.category())
  GUIDE: axis(dim(1), label("Niveau d'instruction"))
  GUIDE: axis(dim(2), label("Quel est votre âge?"))
  GUIDE: text.title(label("Boîte à Moustaches : simple de Quel est votre âge? par Niveau ",
    "d'instruction"))
  SCALE: cat(dim(1), include("1", "2", "3", "4"))
  SCALE: linear(dim(2), include(0))
  ELEMENT: schema(position(bin.quantile.letter(NiveauInstruction*Âge)), label(id))
END GPL.

